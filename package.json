{
  "name": "s3-md-preview.nvim",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "md-preview": "./bin/md-preview"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsx scripts/write-bin.ts",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
